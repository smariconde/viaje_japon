# ─── Telegram (requerido para notificaciones push) ───────────────────────────
# Obtener en https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Tu chat ID — mandar cualquier msg al bot y consultar:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ─── Amadeus API (opcional, fallback si fast-flights falla) ──────────────────
# Registro gratuito en https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# ─── Configuración del bot ────────────────────────────────────────────────────
# Umbral de precio en USD — alertar si el precio baja de este valor
FLIGHT_PRICE_THRESHOLD_USD=1200

# Intervalo de chequeo en minutos
MONITOR_INTERVAL_MINUTES=60

# ─── Ruta de vuelo ────────────────────────────────────────────────────────────
# Origen (IATA) — EZE = Ezeiza Buenos Aires
ORIGIN_IATA=EZE

# Destinos (IATA, separados por coma) — NRT = Narita, HND = Haneda
DESTINATION_IATA=NRT,HND

# Meses objetivo del viaje (YYYY-MM, separados por coma)
# Monitorear ambos meses — el bot busca en los dos y alerta el más barato
TARGET_MONTHS=2027-02,2027-03
